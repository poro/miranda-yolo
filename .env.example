# YOLO Video Game Observer — Environment Configuration
#
# Copy this to .env and fill in your values.
# All settings are optional — the app works in single-user mode without them.

# Supabase (for multi-user authentication)
# Create a free project at https://supabase.com
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_ANON_KEY=eyJ...your-anon-key

# Roboflow (for cloud model training/hosting)
# ROBOFLOW_API_KEY=your-api-key
# ROBOFLOW_PROJECT_ID=your-project-id

# Server
# PORT=6600

# Video library directory (defaults to ~/Documents/src/movies)
# MOVIE_DIR=/path/to/your/gameplay/videos
